# Copy to .env and adjust. docker-compose.yml and the backend both read these.
# .env is gitignored — never commit real secrets.

# --- Postgres (used by docker-compose.yml) ---
POSTGRES_DB=ticketflow1_ticketing
POSTGRES_USER=ticketflow1
POSTGRES_PASSWORD=ticketflow1
# Host port the container publishes on. Default 5433 to avoid clashing with a
# locally-installed Postgres on 5432. The app connects here (see application.yml).
POSTGRES_PORT=5433

# --- Backend (Spring reads these via application.yml placeholders) ---
# JWT signing secret. Must be long enough for HS256 (>= 32 bytes / 256 bits).
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes-long
